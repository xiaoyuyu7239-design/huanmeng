    "s02-fox-cave": {
      "id": "s02-fox-cave",
      "chapter": "第二幕",
      "title": "壁画洞窟",
      "location": "后山洞穴",
      "panorama": "/panoramas/s02-fox-cave.jpg",
      "palette": {
        "from": "#10151f",
        "via": "#31404f",
        "to": "#c78356"
      },
      "synopsis": "壁画上，百年前的教书先生与一位抱书匣的女子一同为狐族立契——那女子，是沈青蘅。",
      "lines": [
        {
          "speaker": "narrator",
          "text": "灵石照亮湿冷岩壁，九尾狐影在壁画之间无声游动。"
        },
        {
          "speaker": "narrator",
          "text": "画上有三个人：重伤的白狐、执笔的教书先生、还有一位把名字签在契尾的女子——她腰间挂着与你同款的书阁腰牌。"
        },
        {
          "speaker": "qing_li",
          "text": "那位先生把名字借给了契约，你姑祖母做了见证。后来天庭追责——一个被罚入轮回，一个被从所有册子里抹去。"
        }
      ],
      "hotspots": [
        {
          "id": "hs02-1",
          "label": "契尾签名",
          "description": "契尾的见证人签名被人凿去，只剩「沈」字的一角。",
          "yaw": -45,
