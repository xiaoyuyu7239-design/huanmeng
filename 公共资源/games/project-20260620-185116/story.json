    "s03-revelation": {
      "id": "s03-revelation",
      "chapter": "第二幕",
      "title": "守契百年",
      "location": "狐仙居所",
      "panorama": "/panoramas/s03-revelation.jpg",
      "palette": {
        "from": "#10151f",
        "via": "#31404f",
        "to": "#c78356"
      },
      "synopsis": "青梨说出全部：执雷官玄岐私改劫册救下狐族，她与见证人沈青蘅一同被连坐。她守契百年，等一个敢把真相写回册子的人。",
      "lines": [
        {
          "speaker": "narrator",
          "text": "居所里月光如水。青梨不再遮掩，九尾在身后缓缓展开——那不是炫耀，是把弱点亮给你看。"
        },
        {
          "speaker": "qing_li",
          "text": "百年前我重伤垂死，是那位先生以自身名姓作保救下我，你姑祖母落笔为证。后来执雷官玄岐偷改劫册保全我族——天庭不能罚神，就罚了签字的人。"
        },
        {
          "speaker": "qing_li",
          "text": "这契百年一续。续契之夜无人落名，守契者替全契受劫——限期，就是这个月圆。借名先生的后人还在村里教书，半份契书，应当还在他家。"
        },
        {
          "speaker": "qing_li",
          "text": "我不要你可怜我。我要你把这件事一个字一个字写清楚——你敢写，我就敢作证。"
        }
      ],
      "hotspots": [
        {
          "id": "hs03-1",
          "label": "风干的珍珠",
          "description": "案上摆着一枚早已风干的珍珠，压着一张写了一半的状纸。传说狐仙落泪成珠——她没有再哭过第二次。",
          "yaw": 0,
          "pitch": -5,
          "effect": {
            "globals": {
              "integrity": 3
            },
            "flags": [
              "hs03-1-found"
            ],
            "memories": [
              "发现线索：一枚旧珍珠压着写了一半的状纸。"
            ]
          }
        }
      ],
      "choices": [
