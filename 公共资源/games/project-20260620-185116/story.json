    "s00-meet-temple": {
      "id": "s00-meet-temple",
      "chapter": "第一幕",
      "title": "古庙借宿",
      "location": "深山古庙",
      "panorama": "/panoramas/s00-meet-temple.jpg",
      "palette": {
        "from": "#10151f",
        "via": "#31404f",
        "to": "#c78356"
      },
      "synopsis": "暴雨之夜，为修订《青丘异闻录》进山的典籍编修沈栖梧躲进古庙，遇见守庙的白衣女子。",
      "lines": [
        {
          "speaker": "narrator",
          "text": "暴雨把山路冲成黑河。你抱紧装书稿的木匣推开古庙残门，烛火在狐仙神像前一盏盏颤动。"
        },
        {
          "speaker": "qing_li",
          "text": "避雨可以。别碰供桌上的东西——那不是给人的。"
        },
        {
          "speaker": "narrator",
          "text": "你亮明来意：书阁典籍编修沈栖梧，奉命修订《青丘异闻录》。她抬眼的瞬间，你在神像与她的眉目之间，看出了同一张脸。"
        }
      ],
      "hotspots": [
        {
          "id": "hs00-1",
          "label": "九道银痕",
          "description": "神像背后的墙上有九道银白色旧痕，像尾影扫过百年的印记。",
          "yaw": 86,
