    "s02-village-secrets": {
      "id": "s02-village-secrets",
      "chapter": "第二幕",
      "title": "村长家",
      "location": "村长家",
      "panorama": "/panoramas/s02-village-secrets.jpg",
      "palette": {
        "from": "#10151f",
        "via": "#31404f",
        "to": "#c78356"
      },
      "synopsis": "村长顾长庚承认：百年来村里靠「送人上山」平息灾祸，你姑祖母就是不肯配合的那一个。",
      "lines": [
        {
          "speaker": "narrator",
          "text": "油灯把老人脸上的皱纹照得像一道道旧伤。听到「沈青蘅」三个字，他握茶碗的手停了停。"
        },
        {
          "speaker": "elder_gu",
          "text": "她当年住的就是顾家老宅。烧她书稿的是我祖父——这事一辈传一辈，传到我这儿，成了不敢说出口的家训。"
        },
        {
          "speaker": "elder_gu",
          "text": "你要写新册子？行。但你的字，要么替全村说话，要么替那只狐狸说话——两边都写，两边都容不下你。"
        },
        {
          "speaker": "elder_gu",
          "text": "村塾的洛先生也来问过青蘅的事。他家祖上，跟这桩案子脱不开干系。"
        }
      ],
      "hotspots": [
        {
          "id": "hs02-3",
          "label": "新镇狐符",
          "description": "供桌下压着一沓镇狐符——纸是新的。村里至今还在防着她。",
          "yaw": 15,
