    "s02-fox-cave": {
      "id": "s02-fox-cave",
      "chapter": "第二幕",
      "title": "狐仙洞穴",
      "location": "后山洞穴",
      "panorama": "/panoramas/s02-fox-cave.jpg",
      "palette": {
        "from": "#10151f",
        "via": "#31404f",
        "to": "#c78356"
      },
      "synopsis": "洞穴深处，灵石闪光，墙上壁画描绘着狐仙的过去。",
      "lines": [
        {
          "speaker": "narrator",
          "voiceProfileId": "narrator",
          "voiceId": "Chinese (Mandarin)_Radio_Host",
          "voiceStatus": "ready",
          "text": "洞穴深处的灵石照亮湿冷岩壁，九尾狐影在壁画之间无声游动。",
          "voiceSrc": "/voices/project-20260620-185116/s02-fox-cave/line-001-11a3a91ea945.mp3",
          "voiceAssetPath": "assets/voices/s02-fox-cave/line-001-11a3a91ea945.mp3",
          "voiceHash": "11a3a91ea945",
          "voiceGeneratedAt": "2026-06-20T11:51:48.291Z"
        },
        {
          "speaker": "narrator",
          "voiceProfileId": "narrator",
          "voiceId": "Chinese (Mandarin)_Radio_Host",
          "voiceStatus": "ready",
          "text": "画上反复出现一个救狐的人影，眉眼与你惊人相似，百年前的因果第一次露出轮廓。",
          "voiceSrc": "/voices/project-20260620-185116/s02-fox-cave/line-002-d3726f41b215.mp3",
          "voiceAssetPath": "assets/voices/s02-fox-cave/line-002-d3726f41b215.mp3",
          "voiceHash": "d3726f41b215",
          "voiceGeneratedAt": "2026-06-20T11:51:49.431Z"
        },
        {
          "speaker": "narrator",
          "voiceProfileId": "narrator",
          "voiceId": "Chinese (Mandarin)_Radio_Host",
          "voiceStatus": "ready",
          "text": "她递来的礼物像救赎也像锁链，你必须决定是接受这份牵连，还是立刻抽身离开。",
          "voiceSrc": "/voices/project-20260620-185116/s02-fox-cave/line-003-e48f1a5de00e.mp3",
          "voiceAssetPath": "assets/voices/s02-fox-cave/line-003-e48f1a5de00e.mp3",
          "voiceHash": "e48f1a5de00e",
          "voiceGeneratedAt": "2026-06-20T11:51:50.806Z"
        }
      ],
