    "s01-escape-village": {
      "id": "s01-escape-village",
      "chapter": "第一幕",
      "title": "青丘村",
      "location": "山间小路",
      "panorama": "/panoramas/s01-escape-village.jpg",
      "palette": {
        "from": "#10151f",
        "via": "#31404f",
        "to": "#c78356"
      },
      "synopsis": "你连夜下山。村口牌坊上「青丘村」三个字，与姑祖母最后一封信里的地名对上了。",
      "lines": [
        {
          "speaker": "narrator",
          "text": "山路泥水没过脚踝。你护着怀里的书稿匣，一步一滑地下了山。"
        },
        {
          "speaker": "narrator",
          "text": "村庄灯火忽明忽暗，更夫的梆子声里混着议论：又有人在庙里见到那位「仙姑」了。"
        },
        {
          "speaker": "you",
          "text": "姑祖母的信里写过这个村子。她失踪前查的，就是这里的狐仙传说。"
        }
      ],
      "hotspots": [
        {
          "id": "hs01-2",
          "label": "村口牌坊",
          "description": "牌坊上「青丘村」三字笔锋清瘦——落款竟是「沈青蘅题」。",
          "yaw": 0,
          "pitch": 15,
          "effect": {
            "globals": {
              "integrity": 3
            },
            "flags": [
              "hs01-2-found"
            ],
            "memories": [
              "发现线索：村口牌坊为姑祖母沈青蘅所题。"
            ]
          }
        }
      ],
      "choices": [
        {
          "id": "ch01-3",
          "label": "去村长家问姑祖母的旧事",
          "next": "s02-village-secrets",
          "fateType": "river",
          "consequence": "老人愿意开口——但他讲的版本里狐仙是灾星，你得自己分辨恐惧与事实。",
          "effect": {
