    "s01-follow-fox": {
      "id": "s01-follow-fox",
      "chapter": "第一幕",
      "title": "守契者的路",
      "location": "古庙后院",
      "panorama": "/panoramas/s01-follow-fox.jpg",
      "palette": {
        "from": "#10151f",
        "via": "#31404f",
        "to": "#c78356"
      },
      "synopsis": "青梨提灯领你穿过庙后浓雾。她说出的名字不是你的——是姑祖母沈青蘅的。",
      "lines": [
        {
          "speaker": "narrator",
          "text": "她提灯走在前面，雾把雨声滤成很轻的沙响。灯焰是冷的银白色，照不暖石阶。"
        },
        {
          "speaker": "qing_li",
          "text": "沈青蘅。百年前也是这样一个雨夜，她抱着一箱书稿站在庙门口。你抱书匣的姿势，和她一模一样。"
        },
        {
          "speaker": "narrator",
          "text": "洞口灵石微光浮动。青梨在洞口顿住，回头看你——她不催，也不解释。"
        }
      ],
      "hotspots": [
        {
          "id": "hs01-1",
          "label": "白玉簪",
          "description": "她袖口露出半截白玉簪——簪头刻纹，与族谱里姑祖母画像上那支一模一样。",
          "yaw": 20,
          "pitch": -5,
          "effect": {
            "globals": {
              "integrity": 3
            },
            "flags": [
              "hs01-1-found"
            ],
            "memories": [
              "发现线索：青梨的白玉簪与姑祖母遗物同款。"
            ]
          }
        }
      ],
      "choices": [
        {
          "id": "ch01-1",
          "label": "随她进洞，看百年前的记录",
          "next": "s02-fox-cave",
          "fateType": "river",
          "consequence": "你走进狐族的记忆现场——从此你写下的每一个字，都有了见证者的分量。",
          "effect": {
            "relationships": {
              "qing_li": {
                "trust": 5
              }
            },
            "flags": [
              "entered_cave"
            ],
            "memories": [
              "洞穴入口"
            ]
          }
        },
        {
          "id": "ch01-2",
          "label": "停下：先问清她与姑祖母的关系",
          "next": "s03-revelation",
          "fateType": "web",
          "consequence": "你用编修的方式提问——按时间、按地点、按证据。她答得也快，真相提前浮出水面。",
          "effect": {
            "relationships": {
              "qing_li": {
                "trust": 8
              }
            },
            "memories": [
              "直接求证"
            ]
          }
        }
      ],
