    "s01-first-choice": {
      "id": "s01-first-choice",
      "chapter": "序幕",
      "title": "镜头里的银线",
      "location": "时代广场",
      "panorama": "/panoramas/s01-first-choice.jpg",
      "palette": {
        "from": "#10151f",
        "via": "#31404f",
        "to": "#c78356"
      },
      "synopsis": "时代广场人流如织。一个背旧相机的男人蹲在路边，镜头对着的不是人群，是你落脚处的银线残迹。",
      "lines": [
        {
          "speaker": "narrator",
          "text": "广场的巨幕把夜照成白昼。你先注意到他的镜头——那台旧相机对着的不是人群，是你落脚点上还没散尽的银线。"
        },
        {
          "speaker": "dong-yong",
          "text": "别紧张，我拍的是光，不是你。这种光，我小时候在爷爷的织机上见过。要看吗？照片可以给你。"
        },
        {
          "speaker": "narrator",
          "text": "他叫董野，拍「正在消失的东西」的纪录片摄影师。相机侧面刻着一枚旧符文——和织坊的护机纹，同源。"
        }
      ],
      "hotspots": [
        {
          "id": "hotspot-camera",
          "label": "护机符文",
          "description": "相机侧面刻着一枚旧符文——织坊护机纹的简写。凡人不该认得这个。",
          "yaw": 20,
          "pitch": -5,
          "effect": {
            "globals": {
              "integrity": 3,
              "fairy_power": 8
            },
            "flags": [
              "hotspot-camera-found"
            ],
            "memories": [
              "发现线索：董野的相机刻着织坊护机纹。"
            ]
          }
        }
      ],
      "choices": [
        {
          "id": "c01-1",
          "label": "看他的照片，问银线的去向",
          "next": "s03-market",
          "fateType": "river",
          "consequence": "他把三个月里拍到的银线残迹都给了你——从此你的行踪，也进了他的镜头故事。",
          "effect": {
            "relationships": {
