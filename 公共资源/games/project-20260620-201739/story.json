    "s02-hidden-clue": {
      "id": "s02-hidden-clue",
      "chapter": "第一章",
      "title": "仙文路标",
      "location": "地下通道",
      "panorama": "/panoramas/s02-hidden-clue.jpg",
      "palette": {
        "from": "#10151f",
        "via": "#31404f",
        "to": "#c78356"
      },
      "synopsis": "地下通道的涂鸦在你眼里亮起来——那不是涂鸦，是仙文路标；落款与织语暗码同一个字：绛。",
      "lines": [
        {
          "speaker": "narrator",
          "text": "通道顶灯坏了一半。墙上的涂鸦在凡人眼里是颜料，在你眼里是发光的仙文——笔画生涩，像用不趁手的工具写的。"
        },
        {
          "speaker": "narrator",
          "text": "路标只有一句：「后来的妹妹，往有玉的地方去。别信管账的，别把织纹给人看。——绛」"
        },
        {
          "speaker": "you",
          "text": "三姐。你到底把自己过成了什么样？"
        }
      ],
      "hotspots": [
        {
          "id": "hotspot-graffiti",
          "label": "仙文落款",
          "description": "落款的「绛」字被反复描过很多遍——像写的人怕它被雨水冲掉。",
          "yaw": 0,
          "pitch": 10,
          "effect": {
            "globals": {
              "integrity": 3,
              "fairy_power": 8
            },
            "flags": [
              "hotspot-graffiti-found"
            ],
            "memories": [
              "发现线索：仙文路标的落款被反复描摹。"
            ]
          }
        }
      ],
      "choices": [
        {
          "id": "c02-1",
          "label": "按路标去古玩市场",
          "next": "s03-market",
          "fateType": "web",
          "consequence": "「有玉的地方」——城隍庙古玩市场。这是三姐给后来者留的路。",
          "effect": {
            "flags": [
              "decoded_graffiti"
            ]
          }
        },
        {
          "id": "c02-2",
          "label": "循着直播声浪直接找她",
          "next": "s05-web-fame",
          "fateType": "river",
          "consequence": "你跳过路标直奔源头——快，但等着你的，是她的主场。",
          "effect": {
            "memories": [
