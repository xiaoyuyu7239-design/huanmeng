# Node 生产源站。公开流量应先经过 HTTPS/CDN；容器内可把 HOST 改成 0.0.0.0。
NODE_ENV=production
HOST=127.0.0.1
PORT=4173

# 慢请求与连接保护（毫秒）；服务端还会钳制在安全范围内。
SERVER_HEADERS_TIMEOUT_MS=15000
SERVER_REQUEST_TIMEOUT_MS=20000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
SERVER_SOCKET_TIMEOUT_MS=45000

# 公开 HTTPS Beta 的 AI 模式由 dist/release.json 固定为 fallback，下面的模型变量不会进入前端产物。
# 玩家关系 AI 仅在服务端读取。不要使用 VITE_ 前缀，也不要提交真实密钥。
# BASE_URL 填 OpenAI-compatible API 根地址；也可直接填以 /chat/completions 结尾的地址。
RELATIONSHIP_AI_BASE_URL=
RELATIONSHIP_AI_API_KEY=
RELATIONSHIP_AI_MODEL=

# 只有确认所选供应商与部署日志满足本产品的数据保留承诺后才设为 true；否则强制备用模式。
RELATIONSHIP_AI_DATA_POLICY_CONFIRMED=false

# 真实模型还必须具备以下生产保护；缺任何一项都会 fail closed 到作者回应。
# SESSION_SECRET 至少 32 个字符，只用于签发 HttpOnly 匿名会话和哈希限流身份。
RELATIONSHIP_AI_SESSION_SECRET=
# npm start 默认使用 Secure Cookie；仅通过纯 HTTP 做本地模型联调时可显式设为 false。
RELATIONSHIP_AI_COOKIE_SECURE=true
# 共享保护服务必须原子实现 /relationship-ai/reserve 与 /relationship-ai/commit（见 README）。
RELATIONSHIP_AI_GUARD_URL=
RELATIONSHIP_AI_GUARD_TOKEN=
# 仅在模型供应商后台已设置账户硬额度后确认。
RELATIONSHIP_AI_PROVIDER_HARD_BUDGET_CONFIRMED=false

# 默认按直连 socket IP 限流。反向代理部署时必须同时配置可信代理精确 IP 与固定跳数；
# 只有直连地址命中白名单时才读取 X-Forwarded-For，不能信任任意来源。
RELATIONSHIP_AI_TRUSTED_PROXY_IPS=
RELATIONSHIP_AI_TRUST_PROXY_HOPS=0

# 由共享保护服务执行的费用与风控参数。
RELATIONSHIP_AI_HOURLY_REQUESTS=18
RELATIONSHIP_AI_GLOBAL_CONCURRENCY=8
RELATIONSHIP_AI_DAILY_TOKEN_BUDGET=30000
RELATIONSHIP_AI_MAX_OUTPUT_TOKENS=64
RELATIONSHIP_AI_TIMEOUT_MS=12000
